# EditorConfig helps maintain consistent coding styles
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
# 마크다운은 공백을 문법으로 쓰는 경우가 있어 트림 비활성화
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{ts,tsx,js,jsx,json}]
indent_size = 2
