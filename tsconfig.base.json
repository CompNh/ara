/*모노레포 전역 TS 규칙(Strict+ESNext)을 고정하고, 패키지별 tsconfig.json이 이를 상속하도록 기반을 만든다.
  - 패키지별 tsconfig.json에서는 별도의 compilerOptions를 지정하지 않고, 필요시 "extends": "../../tsconfig.base.json"만 지정한다.
  - 패키지별 tsconfig.json에서 별도의 compilerOptions를 지정할 경우, 이 파일의 설정과 병합된다.
  - 패키지별 tsconfig.json에서 별도의 compilerOptions를 지정할 경우, 모노레포 전역 규칙과 충돌이 발생할 수 있으므로 주의한다. */
{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noPropertyAccessFromIndexSignature": true,
    "forceConsistentCasingInFileNames": true,
    "importsNotUsedAsValues": "error",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": true,
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@ara/*": ["packages/*/src"]
    }
  },
  "exclude": ["**/dist", "**/build", "node_modules"]
}
