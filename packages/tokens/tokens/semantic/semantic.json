{
  "semantic": {
    "color": {
      "bg": {
        "default": { "value": "{color.surface.base.value}" },
        "raised": { "value": "{color.surface.raised.value}" }
      },
      "fg": {
        "default": { "value": "{color.text.default.value}" },
        "muted": { "value": "{color.text.muted.value}" }
      },
      "brand": {
        "primary": { "value": "{color.brand.primary.value}" },
        "secondary": { "value": "{color.brand.secondary.value}" }
      }
    },
    "border": {
