    },
    "radius": {
      "sm": { "value": "{radius.sm.value}" },
      "md": { "value": "{radius.md.value}" }
    },
    "space": {
      "xs": { "value": "{space.xs.value}" },
      "sm": { "value": "{space.sm.value}" }
    }
  }
