#!/bin/sh
set -e

# 자동 커밋이 재귀로 훅을 또 부르면 스킵
[ -n "$SKIP_AUTO_TASKS" ] && exit 0

LOG="$(git rev-parse --git-dir)/taskhook.log"
{
  echo "==== $(date) post-commit (auto-commit Tasks/WBS; wt vs HEAD) ===="
  REPO_ROOT="$(git rev-parse --show-toplevel)"
  TASKS="$REPO_ROOT/Tasks.csv"
  WBS="$REPO_ROOT/WBS.csv"

  # 중요: 스테이징(--cached) 말고, "작업 트리 vs HEAD" 차이를 본다
  WT_CHANGED=$(git diff --name-only HEAD -- "$TASKS" "$WBS" 2>/dev/null | wc -l | tr -d " ")
  echo "[hook] working-tree changes count: $WT_CHANGED"

  if [ "$WT_CHANGED" -gt 0 ]; then
    BASE="$(git rev-parse --short HEAD)"
    echo "[hook] add+commit on top of $BASE"
    # 변경이 있으면 지금 즉시 스테이징 후 별도 커밋
    git add -A -- "$TASKS" "$WBS" || true
    SKIP_AUTO_TASKS=1 git commit -m "chore: auto apply Tasks/WBS updates (from $BASE)" -- "$TASKS" "$WBS" || true
    echo "[hook] done auto-commit"
  else
    echo "[hook] nothing to commit for Tasks/WBS"
  fi
} >>"$LOG" 2>&1

exit 0
