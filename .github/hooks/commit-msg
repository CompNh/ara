#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="$1"
OUT=".git/TASK_IDS.json"

# [T-****/(완료|done|complete)] 추출 → JSON 배열
IDS=$(grep -oE '\[T-[0-9A-Za-z-]+/(완료|done|complete)\]' "$MSG_FILE" || true | sed -E 's/^\[|\/.*$//g' | sort -u)

if [ -n "${IDS:-}" ]; then
  printf "[" > "$OUT"
  first=1
  for id in $IDS; do
    if [ $first -eq 0 ]; then printf ", " >> "$OUT"; fi
    printf "\"%s\"" "$id" >> "$OUT"
    first=0
  done
  printf "]" >> "$OUT"
else
  : > "$OUT"   # empty file
fi
